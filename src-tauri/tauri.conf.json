{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenJournal",
  "version": "0.3.9",
  "identifier": "com.sparshsam.openjournal",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenJournal",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Sparsh Sam",
    "category": "Productivity",
    "shortDescription": "Privacy-first local activity journal",
    "longDescription": "OpenJournal logs focused window activity locally and generates optional local AI summaries.",
    "copyright": "Copyright Sparsh Sam",
    "license": "AGPL-3.0-or-later",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/Square30x30Logo.png",
      "icons/Square44x44Logo.png",
      "icons/StoreLogo.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": ["https://github.com/sparshsam/openjournal/releases/latest/download/latest.json"],
      "pubkey": "bkFpUGGRXTc3B6ewIPwiOyGfaH1tdMzsRMCa57b3zDE=",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
